# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/job_hunting_assistant
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/job_hunting_assistant

# ── Backend self-reference ───────────────────────────────────────────────
# Used by scrape_service to construct the ingest_callback_url sent to scrapers
BACKEND_BASE_URL=http://localhost:8000

# ── Scraper webhooks ─────────────────────────────────────────────────────
# Phase 1 (OpenClaw direct ingest): leave all three blank
# Phase 2 (n8n): set to your n8n webhook URLs
# Phase 3 (microservice): set to http://scraper:8001/scrape?site=<board>
SCRAPER_WEBHOOK_LINKEDIN=
SCRAPER_WEBHOOK_INDEED=
SCRAPER_WEBHOOK_GLASSDOOR=

# ── LLM — required for Phase 1B matching (not needed yet) ────────────────
ANTHROPIC_API_KEY=

# ── Gmail OAuth2 — required for Phase 1D email monitoring ────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
